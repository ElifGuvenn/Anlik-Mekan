@model AnlikMekanCore.Models.ViewModels.RegisterViewModel
@{ ViewData["Title"] = "Üye Ol"; }

<style>
.auth-wrap { min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 40px 16px; }
.auth-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 40px; width: 100%; max-width: 460px; box-shadow: var(--shadow-md); }
.auth-title { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
.auth-sub { font-size: 14px; color: var(--muted); margin-bottom: 24px; }
.form-group { margin-bottom: 16px; }
.form-label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; }
.form-input { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 14px; font-family: inherit; background: var(--bg); color: var(--text); }
.form-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
.rol-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
.rol-kart { border: 2px solid var(--border); border-radius: 10px; padding: 14px; cursor: pointer; transition: .15s; }
.rol-kart.secili { border-color: var(--primary); background: #eff6ff; }
.rol-kart input { display: none; }
.rol-kart-baslik { font-weight: 700; font-size: 14px; margin-bottom: 4px; }
.rol-kart-acik { font-size: 12px; color: var(--muted); }
.btn-primary { width: 100%; padding: 11px; background: var(--primary); color: white; border: none; border-radius: 8px; font-size: 15px; font-weight: 700; cursor: pointer; }
.btn-primary:hover { background: var(--primary-dark); }
.auth-alt { text-align: center; margin-top: 18px; font-size: 13px; color: var(--muted); }
.auth-alt a { color: var(--primary); font-weight: 600; }
.error-list { background: #fee2e2; color: #991b1b; padding: 10px 14px; border-radius: 8px; font-size: 13px; margin-bottom: 16px; }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-title">Hesap Oluştur</div>
        <div class="auth-sub">Anlık Mekan'a katıl</div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error-list">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@err.ErrorMessage</div> }
            </div>
        }

        <form asp-action="Register" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()

            <p style="font-size:13px;font-weight:700;margin-bottom:10px;">Hesap Türü</p>
            <div class="rol-grid" id="rol-grid">
                <label class="rol-kart @(Model.Rol == "USER" ? "secili" : "")" id="kart-user">
                    <input type="radio" name="Rol" value="USER" @(Model.Rol == "USER" ? "checked" : "")>
                    <div class="rol-kart-baslik">👤 Kullanıcı</div>
                    <div class="rol-kart-acik">Mekanları keşfet, yorum yap</div>
                </label>
                <label class="rol-kart @(Model.Rol == "OWNER" ? "secili" : "")" id="kart-owner">
                    <input type="radio" name="Rol" value="OWNER" @(Model.Rol == "OWNER" ? "checked" : "")>
                    <div class="rol-kart-baslik">🏪 Mekan Sahibi</div>
                    <div class="rol-kart-acik">Mekanını yönet</div>
                </label>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="KullaniciAdi">Kullanıcı Adı</label>
                <input class="form-input" asp-for="KullaniciAdi" placeholder="kullanici_adi">
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Email">E-posta</label>
                <input class="form-input" asp-for="Email" type="email" placeholder="ornek@mail.com">
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Sifre">Şifre</label>
                <input class="form-input" asp-for="Sifre" type="password" placeholder="En az 8 karakter">
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="SifreTekrar">Şifre Tekrar</label>
                <input class="form-input" asp-for="SifreTekrar" type="password" placeholder="••••••••">
            </div>

            <button type="submit" class="btn-primary">Üye Ol</button>
        </form>

        <div class="auth-alt">
            Zaten hesabınız var mı? <a href="@Url.Action("Login","Auth")">Giriş Yap</a>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('input[name="Rol"]').forEach(r => {
    r.addEventListener('change', () => {
        document.querySelectorAll('.rol-kart').forEach(k => k.classList.remove('secili'));
        r.closest('.rol-kart').classList.add('secili');
    });
});
</script>
}
