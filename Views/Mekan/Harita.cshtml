@model List<AnlikMekanCore.Models.Entities.Mekan>
@{ ViewData["Title"] = "Harita"; ViewData["NavHarita"] = true; }

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
.harita-layout { display: grid; grid-template-columns: 320px 1fr; height: calc(100vh - 60px); }
@@media(max-width:768px){.harita-layout{grid-template-columns:1fr;height:auto;}}
.harita-sidebar { border-right: 1px solid var(--border); overflow-y: auto; background: var(--surface); display:flex; flex-direction:column; }
.harita-filtre { padding: 14px; border-bottom: 1px solid var(--border); }
.harita-filtre select { width: 100%; padding: 7px 10px; border: 1.5px solid var(--border); border-radius: 8px; font-family: inherit; font-size: 13px; margin-bottom: 8px; background: var(--bg); color: var(--text); }
.harita-chip-grup { display: flex; flex-wrap: wrap; gap: 6px; }
.harita-chip { padding: 4px 10px; border: 1.5px solid var(--border); border-radius: 16px; font-size: 11px; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--muted); text-decoration: none; white-space: nowrap; }
.harita-chip.aktif { background: var(--primary); color: white; border-color: var(--primary); }
.harita-info { padding: 10px 14px; font-size: 12px; color: var(--muted); border-bottom: 1px solid var(--border); }
.mekan-liste-item { padding: 12px 14px; border-bottom: 1px solid var(--border); cursor: pointer; transition: background .1s; }
.mekan-liste-item:hover { background: var(--bg); }
.item-ad { font-size: 14px; font-weight: 700; margin-bottom: 3px; }
.item-adres { font-size: 12px; color: var(--muted); margin-bottom: 6px; }
.item-badges { display: flex; gap: 6px; flex-wrap: wrap; }
.mini-badge { padding: 2px 7px; border-radius: 4px; font-size: 11px; font-weight: 600; }
.mb-acik { background:#d1fae5;color:#065f46; } .mb-kapali { background:#fee2e2;color:#991b1b; }
#harita-map { height: calc(100vh - 60px); }
@@media(max-width:768px){#harita-map{height:400px;}}
.konum-btn { width: 100%; padding: 8px; background: var(--primary); color: white; border: none; border-radius: 8px; font-family: inherit; font-size: 13px; font-weight: 600; cursor: pointer; margin-bottom: 8px; display:flex; align-items:center; justify-content:center; gap:6px; }
.kat-pin { width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 8px rgba(0,0,0,.3); }
</style>

<div class="harita-layout">
    <div class="harita-sidebar">
        <form method="get" id="harita-form">
            <div class="harita-filtre">
                <button type="button" class="konum-btn" id="konum-btn">
                    <span class="ic"><i data-lucide="navigation"></i></span> Konumuma Göre Sırala
                </button>
                <input type="hidden" name="lat" id="lat-inp" value="@ViewBag.UserLat">
                <input type="hidden" name="lng" id="lng-inp" value="@ViewBag.UserLng">
                @{
                    var qSehir = Context.Request.Query["sehir"].ToString();
                    var qKategori = Context.Request.Query["kategori"].ToString();
                }
                <select name="sehir" onchange="this.form.submit()">
                    <option value="">Tüm Şehirler</option>
                    @foreach (var s in new[]{("istanbul","İstanbul"),("izmir","İzmir"),("samsun","Samsun"),("sakarya","Sakarya"),("balikesir","Balıkesir")})
                    {
                        if (qSehir == s.Item1) { <option value="@s.Item1" selected>@s.Item2</option> }
                        else { <option value="@s.Item1">@s.Item2</option> }
                    }
                </select>
                <select name="kategori" onchange="this.form.submit()">
                    <option value="">Tüm Kategoriler</option>
                    @foreach (var k in new[]{("KAFE","Kafe"),("RESTORAN","Restoran"),("KUTUPHANE","Kütüphane"),("ECZANE","Eczane"),("PUB","Pub")})
                    {
                        if (qKategori == k.Item1) { <option value="@k.Item1" selected>@k.Item2</option> }
                        else { <option value="@k.Item1">@k.Item2</option> }
                    }
                </select>
                <div class="harita-chip-grup">
                    @{
                        var qs = Context.Request.Query;
                        string Chip(string param, string label) {
                            var aktif = !string.IsNullOrEmpty(qs[param]);
                            var href = aktif
                                ? $"?sehir={qs["sehir"]}&kategori={qs["kategori"]}"
                                : $"?{param}=1&sehir={qs["sehir"]}&kategori={qs["kategori"]}";
                            return $"<a href=\"{href}\" class=\"harita-chip{(aktif?" aktif":"")}\">{label}</a>";
                        }
                    }
                    @Html.Raw(Chip("acik","Açık"))
                    @Html.Raw(Chip("wifi","WiFi"))
                    @Html.Raw(Chip("priz","Priz"))
                    @Html.Raw(Chip("bahce","Bahçe"))
                </div>
            </div>
        </form>

        <div class="harita-info">
            @ViewBag.HaritadaMekan konumlu / @ViewBag.ToplamMekan toplam mekan
            @if (ViewBag.AktifKonum is bool b && b) { <strong> — konuma göre sıralı</strong> }
        </div>

        <div id="sidebar-liste" style="flex:1;overflow-y:auto;">
            @{
                var veriler = System.Text.Json.JsonSerializer.Deserialize<List<System.Text.Json.JsonElement>>(
                    ViewBag.HaritaVerisiJson as string ?? "[]");
            }
            @foreach (var item in veriler ?? new())
            {
                var mekanId2 = item.GetProperty("id").GetInt32();
                var ad2 = item.GetProperty("ad").GetString() ?? "";
                var adres2 = item.GetProperty("adres").GetString() ?? "";
                var acik2 = item.GetProperty("suAnAcik").GetBoolean();
                var kat2 = item.GetProperty("kategoriDisplay").GetString() ?? "";
                var mesafe2 = (item.TryGetProperty("mesafeM", out var mp) && mp.ValueKind == System.Text.Json.JsonValueKind.Number) ? (double?)mp.GetDouble() : null;
                var mesafeYazi2 = mesafe2.HasValue ? (mesafe2.Value < 1000 ? $"{(int)mesafe2.Value} m" : $"{mesafe2.Value / 1000:F1} km") : null;
                <div class="mekan-liste-item" onclick="odaklan(@mekanId2)" data-id="@mekanId2">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:6px;">
                        <div class="item-ad">@ad2</div>
                        @if (mesafeYazi2 != null)
                        {
                            <span style="font-size:11px;font-weight:700;color:var(--primary);white-space:nowrap;flex-shrink:0;">📍 @mesafeYazi2</span>
                        }
                    </div>
                    <div class="item-adres">@kat2@(!string.IsNullOrEmpty(adres2) ? " · " + adres2.Substring(0, Math.Min(adres2.Length,40)) : "")</div>
                    <div class="item-badges">
                        @if (acik2) { <span class="mini-badge mb-acik">Açık</span> }
                        else { <span class="mini-badge mb-kapali">Kapalı</span> }
                    </div>
                </div>
            }
        </div>
    </div>

    <div id="harita-map"></div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
var haritaVerisi = @Html.Raw(ViewBag.HaritaVerisiJson ?? "[]");
var markers = {};

// SVG ikonlar (Lucide stilinde)
var katSvg = {
    'KAFE': '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>',
    'RESTORAN': '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>',
    'KUTUPHANE': '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>',
    'ECZANE': '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="m9 3-6 6 6 6"/><path d="m15 3 6 6-6 6"/><line x1="12" y1="7" x2="12" y2="17"/><line x1="8" y1="12" x2="16" y2="12"/></svg>',
    'PUB': '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M17 11h1a3 3 0 0 1 0 6h-1"/><path d="M9 12v6"/><path d="M13 12v6"/><path d="M14 7.5c-1 0-1.44.5-3 .5s-2-.5-3-.5-1.44.5-3 .5"/><path d="M3 11V7.5"/><path d="M17 11V7.5"/><path d="M3 7.5C3 5 5.5 3 9 3s6 1.5 6 3"/><line x1="7" y1="19" x2="17" y2="19"/></svg>'
};
var defaultSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>';

function ikonHtml(kat, acik) {
    var bg = acik ? '#10b981' : '#ef4444';
    var svg = katSvg[kat] || defaultSvg;
    return '<div style="background:' + bg + ';border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,.35);border:2px solid rgba(255,255,255,.6)">' + svg + '</div>';
}

var map = L.map('harita-map').setView([39.9, 32.8], 6);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
}).addTo(map);

haritaVerisi.forEach(function(m) {
    if (!m.lat && m.lat !== 0) return;
    if (!m.lng && m.lng !== 0) return;
    var ikon = L.divIcon({ html: ikonHtml(m.kategori, m.suAnAcik), iconSize:[32,32], iconAnchor:[16,16], popupAnchor:[0,-16], className:'' });
    var ad = m.ad ? m.ad.replace(/</g,'&lt;').replace(/>/g,'&gt;') : '';
    var popup = '<div style="min-width:190px;font-family:Inter,sans-serif">'
        + '<strong style="font-size:14px">' + ad + '</strong><br>'
        + '<small style="color:#64748b">' + (m.kategoriDisplay||'') + '</small><br><br>'
        + (m.ortPuan ? '<span style="color:#f59e0b">★ ' + m.ortPuan.toFixed(1) + '</span> · ' + (m.yorumSayisi||0) + ' yorum<br>' : '')
        + (m.dolulukOrani !== null && m.dolulukOrani !== undefined ? 'Doluluk: %' + m.dolulukOrani + '<br>' : '')
        + '<span style="color:' + (m.suAnAcik?'#10b981':'#ef4444') + ';font-weight:600">' + (m.suAnAcik?'Açık':'Kapalı') + '</span>'
        + '<br><a href="' + m.detayUrl + '" style="color:#2563eb;font-weight:600;font-size:13px">Detaya git →</a>'
        + '</div>';
    var marker = L.marker([m.lat, m.lng], {icon: ikon}).addTo(map).bindPopup(popup);
    markers[m.id] = marker;
});

function odaklan(id) {
    var m = markers[id];
    if (m) { map.setView(m.getLatLng(), 16); m.openPopup(); }
    document.getElementById('sidebar-liste').querySelectorAll('.mekan-liste-item').forEach(function(el){
        el.style.background = el.dataset.id == id ? 'var(--bg)' : '';
    });
}

@if (ViewBag.AktifKonum is bool av && av && !string.IsNullOrEmpty(ViewBag.UserLat?.ToString()))
{
    @Html.Raw($"var uLat={ViewBag.UserLat};var uLng={ViewBag.UserLng};")
    @:L.circleMarker([uLat,uLng],{radius:10,color:'#6366f1',fillColor:'#6366f1',fillOpacity:0.8}).addTo(map).bindPopup('<b>Konumunuz</b>');
    @:map.setView([uLat,uLng],13);
}

document.getElementById('konum-btn').addEventListener('click', function() {
    if (!navigator.geolocation) { alert('Tarayıcınız konum özelliğini desteklemiyor.'); return; }
    this.disabled = true; this.textContent = 'Konum alınıyor...';
    navigator.geolocation.getCurrentPosition(function(pos) {
        document.getElementById('lat-inp').value = pos.coords.latitude;
        document.getElementById('lng-inp').value = pos.coords.longitude;
        document.getElementById('harita-form').submit();
    }, function() { alert('Konum alınamadı. Lütfen izin verin.'); document.getElementById('konum-btn').disabled = false; });
});
</script>
