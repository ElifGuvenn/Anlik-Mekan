@{
    ViewData["Title"] = "Profilim";
    var user = (AnlikMekanCore.Models.AppUser)ViewBag.Kullanici;
    var yorumlar = (List<AnlikMekanCore.Models.Entities.Yorum>)ViewBag.Yorumlar;
    var favoriler = (List<AnlikMekanCore.Models.Entities.Mekan>)ViewBag.Favoriler;
}

<style>
.profil-wrap { max-width: 860px; margin: 0 auto; padding: 36px 24px 80px; }
.mesaj-basari { background: #dcfce7; border: 1px solid #bbf7d0; border-radius: 8px; padding: 11px 16px; font-size: 14px; font-weight: 600; color: #15803d; margin-bottom: 16px; }
.profil-header { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 28px; margin-bottom: 24px; display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
.avatar { width: 72px; height: 72px; border-radius: 50%; background: var(--primary); color: white; font-size: 28px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
.avatar img { width: 100%; height: 100%; object-fit: cover; }
.profil-bilgi h1 { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
.profil-bilgi p { font-size: 13px; color: var(--muted); margin-bottom: 8px; }
.profil-stat-row { display: flex; gap: 20px; flex-wrap: wrap; }
.stat-item { text-align: center; }
.stat-sayi { font-size: 20px; font-weight: 800; display: block; }
.stat-label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .4px; }
.profil-header-actions { margin-left: auto; display: flex; flex-direction: column; gap: 8px; align-items: flex-end; }
.btn-kucuk { padding: 7px 16px; border-radius: 7px; font-size: 13px; font-weight: 600; border: 1.5px solid var(--border); background: var(--surface); color: var(--text); transition: .15s; text-decoration: none; text-align: center; }
.btn-kucuk:hover { background: var(--bg); color: var(--text); }
.btn-kucuk-blue { background: var(--primary); color: white; border-color: var(--primary); }
.btn-kucuk-blue:hover { opacity: .9; color: white; }
.sekme-bar { display: flex; gap: 2px; border-bottom: 1px solid var(--border); margin-bottom: 24px; overflow-x: auto; }
.sekme { padding: 10px 18px; font-size: 14px; font-weight: 600; color: var(--muted); border: none; border-bottom: 2px solid transparent; cursor: pointer; background: none; font-family: inherit; white-space: nowrap; transition: .15s; }
.sekme:hover { color: var(--text); }
.sekme.aktif { color: var(--primary); border-bottom-color: var(--primary); }
.sekme-icerik { display: none; }
.sekme-icerik.goster { display: block; }
.yorum-kart { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 18px; margin-bottom: 12px; }
.yorum-kart-ust { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; gap: 12px; flex-wrap: wrap; }
.mekan-link { font-size: 14px; font-weight: 700; color: var(--primary); text-decoration: none; }
.mekan-link:hover { text-decoration: underline; }
.yorum-puan { color: #f59e0b; font-size: 13px; }
.yorum-tarih { font-size: 12px; color: var(--muted); }
.yorum-icerik { font-size: 14px; line-height: 1.7; }
.favori-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
.favori-kart { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: transform .2s; display: block; text-decoration: none; color: inherit; }
.favori-kart:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.favori-kart-ph { width: 100%; height: 110px; background: #e2e8f0; display: flex; align-items: center; justify-content: center; font-size: 28px; }
.favori-kart img { width: 100%; height: 110px; object-fit: cover; display: block; }
.favori-kart-body { padding: 12px; }
.favori-kart-name { font-size: 14px; font-weight: 700; margin-bottom: 3px; }
.favori-kart-cat { font-size: 11px; color: var(--muted); font-weight: 600; text-transform: uppercase; }
.form-kart { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 24px; max-width: 420px; margin-bottom: 16px; }
.form-kart h3 { font-size: 16px; font-weight: 800; margin-bottom: 16px; }
.f-grup { margin-bottom: 16px; }
.f-label { display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 5px; text-transform: uppercase; letter-spacing: .3px; }
.f-input { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 8px; font-size: 14px; font-family: inherit; background: var(--bg); box-sizing: border-box; }
.f-input:focus { outline: none; border-color: var(--primary); }
.btn-kaydet { padding: 10px 20px; background: var(--primary); color: white; border: none; border-radius: 8px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; }
.bos-durum { text-align: center; padding: 48px 20px; color: var(--muted); }
.bos-durum h3 { font-size: 17px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
</style>

<div class="profil-wrap">

    @if (TempData["Mesaj"] != null)
    { <div class="mesaj-basari">✓ @TempData["Mesaj"]</div> }

    <div class="profil-header">
        <div class="avatar">
            @if (!string.IsNullOrEmpty(user.FotoUrl))
            { <img src="@user.FotoUrl" alt="@user.UserName"> }
            else
            { <text>@(user.UserName?.Substring(0,1).ToUpper())</text> }
        </div>
        <div class="profil-bilgi">
            <h1>@user.UserName</h1>
            <p>@(string.IsNullOrEmpty(user.Email) ? "E-posta eklenmemiş" : user.Email)</p>
            <div class="profil-stat-row">
                <div class="stat-item">
                    <span class="stat-sayi">@ViewBag.YorumSayisi</span>
                    <span class="stat-label">Yorum</span>
                </div>
                <div class="stat-item">
                    <span class="stat-sayi">@ViewBag.FavoriSayisi</span>
                    <span class="stat-label">Favori</span>
                </div>
            </div>
        </div>
        <div class="profil-header-actions">
            @if (user.Rol == "OWNER")
            { <a href="@Url.Action("Dashboard","Owner")" class="btn-kucuk btn-kucuk-blue">Mekan Panelim</a> }
            <a href="@Url.Action("SifreSifirla","Auth")" class="btn-kucuk">Şifre Değiştir</a>
        </div>
    </div>

    <div class="sekme-bar">
        @if (user.Rol != "OWNER")
        {
            <button class="sekme aktif" onclick="sekmeAc(this,'tab-yorumlar')"><span class="ic"><i data-lucide="message-circle"></i></span> Yorumlarım (@ViewBag.YorumSayisi)</button>
            <button class="sekme" onclick="sekmeAc(this,'tab-favoriler')"><span class="ic"><i data-lucide="heart"></i></span> Favorilerim (@ViewBag.FavoriSayisi)</button>
            <button class="sekme" onclick="window.location.href='@Url.Action("Index","Liste")'"><span class="ic"><i data-lucide="list"></i></span> Listelerim</button>
        }
        <button class="sekme @(user.Rol == "OWNER" ? "aktif" : "")" onclick="sekmeAc(this,'tab-hesap')"><span class="ic"><i data-lucide="settings"></i></span> Hesap Ayarları</button>
    </div>

    @if (user.Rol == "OWNER")
    {
        <script>document.addEventListener('DOMContentLoaded',function(){ document.querySelectorAll('.sekme-icerik').forEach(t=>t.classList.remove('goster')); var h=document.getElementById('tab-hesap'); if(h) h.classList.add('goster'); });</script>
    }

    <div id="tab-yorumlar" class="sekme-icerik goster">
        @if (!yorumlar.Any())
        {
            <div class="bos-durum">
                <h3>Henüz yorum yapmadın</h3>
                <p>Mekan detay sayfalarından yorum bırakabilirsin.</p>
            </div>
        }
        @foreach (var y in yorumlar)
        {
            <div class="yorum-kart">
                <div class="yorum-kart-ust">
                    <a href="@Url.Action("Detay","Mekan",new{id=y.MekanId})" class="mekan-link">@y.Mekan?.Ad</a>
                    <div style="display:flex;align-items:center;gap:10px;">
                        @if (y.Puan.HasValue)
                        { <span class="yorum-puan">@string.Concat(Enumerable.Repeat("★", y.Puan.Value))@string.Concat(Enumerable.Repeat("☆", 5 - y.Puan.Value))</span> }
                        <span class="yorum-tarih">@y.Tarih.ToString("dd MMM yyyy")</span>
                    </div>
                </div>
                <p class="yorum-icerik">@y.Icerik</p>
            </div>
        }
    </div>

    <div id="tab-favoriler" class="sekme-icerik">
        @if (!favoriler.Any())
        {
            <div class="bos-durum">
                <h3>Henüz favori eklemedin</h3>
                <p>Mekan kartlarındaki 🤍 butonuna tıklayarak favori ekleyebilirsin.</p>
            </div>
        }
        else
        {
            <div class="favori-grid">
                @foreach (var m in favoriler)
                {
                    <a href="@Url.Action("Detay","Mekan",new{id=m.Id})" class="favori-kart">
                        @if (!string.IsNullOrEmpty(m.ImgUrl))
                        { <img src="@m.ImgUrl" alt="@m.Ad"> }
                        else
                        { <div class="favori-kart-ph">@(m.Kategori=="KAFE"?"☕":m.Kategori=="RESTORAN"?"🍽️":m.Kategori=="KUTUPHANE"?"📚":m.Kategori=="ECZANE"?"💊":"🍺")</div> }
                        <div class="favori-kart-body">
                            <div class="favori-kart-name">@m.Ad</div>
                            <div class="favori-kart-cat">@m.KategoriAdi</div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>

    <div id="tab-hesap" class="sekme-icerik">
        <div class="form-kart" style="margin-bottom:16px;">
            <h3>Profil Fotoğrafı</h3>
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:16px;">
                <div class="avatar" style="width:64px;height:64px;font-size:22px;">
                    @if (!string.IsNullOrEmpty(user.FotoUrl))
                    { <img src="@user.FotoUrl" alt="Profil"> }
                    else { <text>@(user.UserName?.Substring(0,1).ToUpper())</text> }
                </div>
                <form method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="islem" value="foto">
                    <input type="file" name="foto" accept="image/*" id="foto-input" style="display:none" onchange="this.form.submit()">
                    <label for="foto-input" class="btn-kaydet" style="cursor:pointer;display:inline-block;">📷 Fotoğraf Yükle</label>
                </form>
            </div>
        </div>

        <div class="form-kart">
            <h3>E-posta Güncelle</h3>
            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="islem" value="email">
                <div class="f-grup">
                    <label class="f-label">E-posta Adresi</label>
                    <input type="email" name="email" class="f-input" value="@user.Email" placeholder="ornek@email.com">
                </div>
                <button type="submit" class="btn-kaydet">Kaydet</button>
            </form>
        </div>
    </div>

</div>

<script>
function sekmeAc(btn, tabId) {
    document.querySelectorAll('.sekme').forEach(s => s.classList.remove('aktif'));
    document.querySelectorAll('.sekme-icerik').forEach(t => t.classList.remove('goster'));
    btn.classList.add('aktif');
    document.getElementById(tabId).classList.add('goster');
}
</script>
