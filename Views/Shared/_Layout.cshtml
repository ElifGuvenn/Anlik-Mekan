<!DOCTYPE html>
<html lang="tr" id="html-root">
<head>
    <script>(function(){var t=localStorage.getItem('am-theme');if(t==='dark')document.documentElement.setAttribute('data-theme','dark');})()</script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Anlık Mekan</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    @await RenderSectionAsync("ExtraHead", required: false)
    <style>
        :root {
            --primary: #2563eb; --primary-dark: #1d4ed8;
            --surface: #ffffff; --bg: #f8fafc; --border: #e2e8f0;
            --text: #0f172a; --muted: #64748b;
            --success: #059669; --danger: #dc2626;
            --radius: 12px;
            --shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.05);
            --shadow-md: 0 4px 6px rgba(0,0,0,.04), 0 10px 28px rgba(0,0,0,.07);
        }
        [data-theme="dark"] {
            --primary: #3b82f6; --primary-dark: #2563eb;
            --surface: #1e293b; --bg: #0f172a; --border: #334155;
            --text: #f1f5f9; --muted: #94a3b8;
            --success: #34d399; --danger: #f87171;
            --shadow: 0 1px 3px rgba(0,0,0,.3), 0 4px 12px rgba(0,0,0,.25);
            --shadow-md: 0 4px 6px rgba(0,0,0,.25), 0 10px 28px rgba(0,0,0,.35);
        }
        [data-theme="dark"] .navbar, [data-theme="dark"] .subnav { background: #1e293b; }
        [data-theme="dark"] .footer { background: #020617; }
        [data-theme="dark"] input, [data-theme="dark"] textarea, [data-theme="dark"] select {
            background: #0f172a !important; color: #f1f5f9 !important; border-color: #334155 !important;
        }
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text);
               min-height: 100vh; display: flex; flex-direction: column; font-size: 15px; line-height: 1.6; }
        a { text-decoration: none; color: inherit; }
        .navbar { background: var(--surface); border-bottom: 1px solid var(--border);
                  padding: 0 5%; display: flex; align-items: center; height: 60px; gap: 20px;
                  position: sticky; top: 0; z-index: 100; }
        .navbar-logo { display: flex; align-items: center; gap: 10px; font-size: 16px; font-weight: 900; }
        .logo-mark { width: 30px; height: 30px; background: linear-gradient(135deg,#6366f1,#8b5cf6);
                     border-radius: 8px; display: flex; align-items: center; justify-content: center;
                     color: white; font-size: 13px; font-weight: 900; }
        .navbar-search { flex: 1; max-width: 400px; position: relative; }
        .navbar-search input { width: 100%; padding: 8px 14px; border: 1.5px solid var(--border);
                                border-radius: 8px; font-size: 14px; background: var(--bg); color: var(--text); }
        .navbar-search input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,.1); }
        .navbar-right { display: flex; align-items: center; gap: 10px; margin-left: auto; }
        .navbar-username { font-size: 13px; font-weight: 600; color: var(--muted); display: flex; align-items: center; gap: 8px; }
        .navbar-username strong { color: var(--text); font-weight: 700; }
        .nav-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--primary); color: white;
                      font-size: 13px; font-weight: 800; display: flex; align-items: center; justify-content: center;
                      border: 2px solid var(--border); text-decoration: none; overflow: hidden; }
        .nav-avatar img { width: 100%; height: 100%; object-fit: cover; }
        .role-pill { font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px;
                     background: #eff6ff; color: var(--primary); }
        .dark-toggle { width: 34px; height: 34px; border: 1.5px solid var(--border); border-radius: 8px;
                       background: var(--bg); color: var(--text); font-size: 16px; cursor: pointer;
                       display: flex; align-items: center; justify-content: center; }
        .notif-bell { position: relative; width: 34px; height: 34px; border: 1.5px solid var(--border);
                      border-radius: 8px; background: var(--bg); color: var(--text); cursor: pointer;
                      display: flex; align-items: center; justify-content: center; text-decoration: none; }
        .notif-badge { position: absolute; top: -5px; right: -5px; background: #dc2626; color: white;
                       font-size: 10px; font-weight: 800; min-width: 17px; height: 17px; border-radius: 9px;
                       display: flex; align-items: center; justify-content: center; padding: 0 4px; }
        .btn-nav { padding: 7px 15px; border-radius: 7px; font-size: 13px; font-weight: 600;
                   cursor: pointer; border: none; font-family: inherit; display: inline-flex; align-items: center; }
        .btn-outline { background: transparent; color: var(--text); border: 1.5px solid var(--border); }
        .btn-solid { background: var(--primary); color: white; }
        .btn-solid:hover { background: var(--primary-dark); }
        .btn-ghost-danger { background: transparent; color: var(--danger); border: 1.5px solid #fca5a5; }
        .subnav { background: var(--surface); border-bottom: 1px solid var(--border);
                  padding: 0 5%; display: flex; gap: 2px; overflow-x: auto; }
        .subnav-link { padding: 11px 14px; font-size: 13px; font-weight: 500; color: var(--muted);
                       border-bottom: 2px solid transparent; white-space: nowrap; }
        .subnav-link:hover { color: var(--text); }
        .subnav-link.active { color: var(--primary); border-bottom-color: var(--primary); font-weight: 600; }
        main { flex: 1; }
        .footer { background: linear-gradient(135deg,#0f172a,#1e1b4b); color: #94a3b8;
                  padding: 36px 5%; margin-top: 80px; display: flex; align-items: center;
                  justify-content: space-between; gap: 20px; flex-wrap: wrap; }
        .footer-logo { font-size: 14px; font-weight: 800; color: white; }
        .ic { display:inline-flex; align-items:center; justify-content:center; }
        .ic svg { width:1em; height:1em; stroke:currentColor; stroke-width:2; fill:none; stroke-linecap:round; stroke-linejoin:round; vertical-align:middle; }
        #search-dropdown { position:absolute; top:calc(100% + 6px); left:0; right:0;
                           background:var(--bg); border:1.5px solid var(--border); border-radius:10px;
                           box-shadow:var(--shadow-md); overflow:hidden; z-index:9999; display:none; }
        #search-dropdown.open { display:block; }
        .sd-item { display:flex; align-items:center; gap:10px; padding:10px 14px; text-decoration:none; color:var(--text); }
        .sd-item:hover { background:var(--surface); }
        .sd-item-name { font-weight:600; font-size:14px; flex:1; }
        .sd-item-meta { font-size:12px; color:var(--muted); white-space:nowrap; }
        .alert { padding: 12px 16px; border-radius: 8px; margin: 16px 5%; font-size: 14px; }
        .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #6ee7b7; }
        .alert-danger { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        .mesafe-badge { display:inline-flex; align-items:center; gap:4px; font-size:11px; font-weight:700; color:#2563eb; background:#eff6ff; border-radius:5px; padding:2px 7px; }
        @await RenderSectionAsync("ExtraCss", required: false)
    </style>
</head>
<body>

<header class="navbar">
    @if (User.Identity?.IsAuthenticated == true)
    {
        var rol = User.FindFirst("Rol")?.Value ?? "USER";
        <a href="@(rol == "OWNER" ? Url.Action("Dashboard","Owner") : Url.Action("Dashboard","Home"))" class="navbar-logo">
            <div class="logo-mark">A</div> Anlık Mekan
        </a>
        @if (rol != "OWNER")
        {
            <form asp-controller="Home" asp-action="Arama" method="GET" class="navbar-search" autocomplete="off" id="search-form">
                <input type="text" name="q" id="search-input" placeholder="Mekan, adres veya şehir ara..."
                       value="@Context.Request.Query["q"]">
                <input type="hidden" name="filtre" id="search-filtre" value="@ViewBag.Filtre">
                <div id="search-dropdown"></div>
            </form>
        }
    }
    else
    {
        <a href="@Url.Action("Landing","Home")" class="navbar-logo">
            <div class="logo-mark">A</div> Anlık Mekan
        </a>
    }

    <div class="navbar-right">
        <button class="dark-toggle" onclick="toggleDark()" title="Karanlık Mod">
            <span class="ic" id="dark-toggle-icon"><i data-lucide="moon"></i></span>
        </button>

        @if (User.Identity?.IsAuthenticated == true)
        {
            var kullaniciAdi = User.Identity.Name ?? "";
            var rol = User.FindFirst("Rol")?.Value ?? "USER";
            var foto = User.FindFirst("FotoUrl")?.Value;

            <a href="@Url.Action("Index","Bildirim")" class="notif-bell" id="notif-bell-link">
                <span class="ic"><i data-lucide="bell"></i></span>
                <span class="notif-badge" id="notif-badge" style="display:none;">0</span>
            </a>
            <a href="@Url.Action("Index","Profil")" class="nav-avatar">
                @if (!string.IsNullOrEmpty(foto))
                {
                    <img src="@foto" alt="@kullaniciAdi">
                }
                else
                {
                    @(kullaniciAdi.Length > 0 ? kullaniciAdi[0].ToString().ToUpper() : "?")
                }
            </a>
            <span class="navbar-username">
                @if (rol == "OWNER") { <span class="role-pill">İşletme</span> }
                <a href="@Url.Action("Index","Profil")" style="color:inherit;font-weight:700;">@kullaniciAdi</a>
            </span>
            <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-nav btn-ghost-danger">Çıkış</button>
            </form>
        }
        else
        {
            <a href="@Url.Action("Login","Auth")" class="btn-nav btn-solid">Giriş Yap / Üye Ol</a>
        }
    </div>
</header>

@if (User.Identity?.IsAuthenticated == true)
{
    var rol = User.FindFirst("Rol")?.Value ?? "USER";
    <nav class="subnav">
        @if (rol == "OWNER")
        {
            <a href="@Url.Action("Dashboard","Owner")" class="subnav-link @(ViewData["NavPanel"] != null ? "active" : "")">Panelim</a>
            <a href="@Url.Action("MekanOlustur","Owner")" class="subnav-link @(ViewData["NavYeni"] != null ? "active" : "")">Yeni Mekan</a>
            <a href="@Url.Action("Index","Bildirim")" class="subnav-link">Bildirimler</a>
        }
        else
        {
            <a href="@Url.Action("Dashboard","Home")" class="subnav-link @(ViewData["NavHome"] != null ? "active" : "")">Tüm Mekanlar</a>
            <a href="@Url.Action("Harita","Mekan")" class="subnav-link @(ViewData["NavHarita"] != null ? "active" : "")"><span class="ic"><i data-lucide="map"></i></span> Harita</a>
            <a href="@Url.Action("CalismaAlanlari","Home")" class="subnav-link">Çalışma Alanları</a>
            <a href="@Url.Action("Favorilerim","Home")" class="subnav-link">Favorilerim</a>
            <a href="@Url.Action("Index","Liste")" class="subnav-link">Listelerim</a>
            <a href="@Url.Action("Index","Rezervasyon")" class="subnav-link">Rezervasyonlarım</a>
            <a href="@Url.Action("PopulerMekanlar","Home")" class="subnav-link">Popüler</a>
        }
    </nav>
}

@if (TempData["Mesaj"] != null)
{
    <div class="alert alert-success">@TempData["Mesaj"]</div>
}
@if (TempData["Hata"] != null)
{
    <div class="alert alert-danger">@TempData["Hata"]</div>
}

<main>
    @RenderBody()
</main>

<footer class="footer">
    <div class="footer-logo">Anlık Mekan</div>
    <div style="font-size:12px;color:#64748b;">© 2025 Anlık Mekan. Tüm hakları saklıdır.</div>
</footer>

<script>
function toggleDark() {
    const root = document.documentElement;
    const isDark = root.getAttribute('data-theme') === 'dark';
    root.setAttribute('data-theme', isDark ? 'light' : 'dark');
    localStorage.setItem('am-theme', isDark ? 'light' : 'dark');
    setDarkIcon(!isDark);
}
function setDarkIcon(isDark) {
    const w = document.getElementById('dark-toggle-icon');
    if (!w) return;
    w.innerHTML = isDark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
    if (typeof lucide !== 'undefined') lucide.createIcons();
}
document.addEventListener('DOMContentLoaded', () => {
    setDarkIcon(document.getElementById('html-root').getAttribute('data-theme') === 'dark');
});
</script>

@if (User.Identity?.IsAuthenticated == true)
{
    <script>
    function guncelleBildirimBadge() {
        fetch('@Url.Action("Sayi","Bildirim")')
            .then(r => r.json())
            .then(data => {
                const badge = document.getElementById('notif-badge');
                if (!badge) return;
                if (data.sayi > 0) { badge.textContent = data.sayi > 99 ? '99+' : data.sayi; badge.style.display = 'flex'; }
                else { badge.style.display = 'none'; }
            }).catch(() => {});
    }
    guncelleBildirimBadge();
    setInterval(guncelleBildirimBadge, 60000);
    </script>
    <script>
    (function () {
        const input = document.getElementById('search-input');
        const dropdown = document.getElementById('search-dropdown');
        if (!input) return;
        let timer;
        const katAdi = {KAFE:'Kafe',KUTUPHANE:'Kütüphane',ECZANE:'Eczane',RESTORAN:'Restoran',PUB:'Pub'};
        function render(sonuclar) {
            if (!sonuclar.length) { dropdown.innerHTML = '<div style="padding:12px;font-size:13px;color:var(--muted);text-align:center">Sonuç bulunamadı</div>'; }
            else { dropdown.innerHTML = sonuclar.map(m => `<a class="sd-item" href="/Mekan/Detay/${m.id}"><span class="sd-item-name">${m.ad}</span><span class="sd-item-meta">${katAdi[m.kategori]||m.kategori}${m.sehir?' · '+m.sehir:''}</span></a>`).join(''); }
            dropdown.classList.add('open');
        }
        input.addEventListener('input', function() {
            clearTimeout(timer);
            const q = this.value.trim();
            if (!q) { dropdown.classList.remove('open'); return; }
            timer = setTimeout(() => {
                const filtre = document.getElementById('search-filtre')?.value || '';
                fetch(`/Home/AramaApi?q=${encodeURIComponent(q)}${filtre?'&filtre='+filtre:''}`)
                    .then(r => r.json()).then(d => render(d.sonuclar)).catch(() => dropdown.classList.remove('open'));
            }, 180);
        });
        document.addEventListener('click', e => { if (!document.getElementById('search-form')?.contains(e.target)) dropdown.classList.remove('open'); });
    })();
    </script>
}

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>document.addEventListener('DOMContentLoaded', () => lucide.createIcons());</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
